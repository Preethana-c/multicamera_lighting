# ─────────────────────────────────────────────────────────────────────────────
# Environment template. Copy to .env and fill in your site's values:
#     cp .env.example .env        (PowerShell: Copy-Item .env.example .env)
# .env holds real secrets and is gitignored — never commit it.
# ─────────────────────────────────────────────────────────────────────────────

# ── Cameras (RTSP) ────────────────────────────────────────────────────────────
CAM_USER=
CAM_PASS=
CAM_RTSP_PORT=
CAM_RTSP_PATH=

CAM1_IP=
CAM2_IP=
CAM3_IP=
CAM4_IP=

# ── Local MQTT broker (Mosquitto) ─────────────────────────────────────────────
MQTT_HOST=
MQTT_PORT=

# ── Real light gateway (Bluetooth-mesh) ───────────────────────────────────────
# Set REAL_LIGHTS_ENABLED=false to run simulation only (physical lights untouched).
REAL_LIGHTS_ENABLED=
REAL_BROKER=
REAL_PORT=
REAL_USER=
REAL_PWD=
REAL_CMD_TOPIC=
REAL_MSG_TOPIC=

# ── Servers / ports ───────────────────────────────────────────────────────────
MJPEG_PORT=
UI_PORT=
